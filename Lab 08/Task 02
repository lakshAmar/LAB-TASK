#include <stdio.h>

int main(){

    int seats[5][6];
    int i,j;
    int available=0;
    int maxRow=0,maxBooked=0;

    printf("Enter seat status (0=Available, 1=Booked):\n");

    for(i=0;i<5;i++){
        for(j=0;j<6;j++){
            scanf("%d",&seats[i][j]);
        }
    }

    for(i=0;i<5;i++){

        int booked=0;

        for(j=0;j<6;j++){

            if(seats[i][j]==0)
                available++;

            if(seats[i][j]==1)
                booked++;
        }

        if(booked>maxBooked){
            maxBooked=booked;
            maxRow=i;
        }
    }

    printf("Available seats = %d\n",available);
    printf("Row with maximum booked seats = %d\n",maxRow+1);

    return 0;
}
