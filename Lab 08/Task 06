#include <stdio.h>

int main(){

    int a[3][3],b[3][3],c[3][3];
    int r1,c1,r2,c2;
    int i,j,k;

    printf("Enter rows and columns of Matrix A: ");
    scanf("%d %d",&r1,&c1);

    printf("Enter rows and columns of Matrix B: ");
    scanf("%d %d",&r2,&c2);

    if(c1!=r2){
        printf("Multiplication not possible\n");
        return 0;
    }

    printf("Enter Matrix A:\n");

    for(i=0;i<r1;i++)
        for(j=0;j<c1;j++)
            scanf("%d",&a[i][j]);

    printf("Enter Matrix B:\n");

    for(i=0;i<r2;i++)
        for(j=0;j<c2;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<r1;i++){
        for(j=0;j<c2;j++){

            c[i][j]=0;

            for(k=0;k<c1;k++){
                c[i][j]+=a[i][k]*b[k][j];
            }
        }
    }

    printf("Result Matrix:\n");

    for(i=0;i<r1;i++){
        for(j=0;j<c2;j++){
            printf("%d ",c[i][j]);
        }
        printf("\n");
    }

    return 0;
}
