#include <stdio.h>

int main() {

    int marks[4][3];
    int i,j,total;

    printf("Enter marks of 4 students in 3 subjects:\n");

    for(i=0;i<4;i++){
        for(j=0;j<3;j++){
            printf("Student %d Subject %d: ",i+1,j+1);
            scanf("%d",&marks[i][j]);
        }
    }

    printf("\nTotal marks of each student:\n");

    for(i=0;i<4;i++){
        total=0;

        for(j=0;j<3;j++){
            total+=marks[i][j];
        }

        printf("Student %d Total = %d\n",i+1,total);
    }

    printf("\nAverage marks of each subject:\n");

    for(j=0;j<3;j++){
        total=0;

        for(i=0;i<4;i++){
            total+=marks[i][j];
        }

        printf("Subject %d Average = %.2f\n",j+1,total/4.0);
    }

    return 0;
}
